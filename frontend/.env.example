# --- public (sent to the browser) ---
# Which HashKey Chain to target: 177 = mainnet, 133 = testnet.
NEXT_PUBLIC_CHAIN_ID=177

# --- server-only (used by the /api/underwrite Route Handler; NEVER exposed to the client) ---
# Underwriter signer — must equal CreditManager.underwriter on-chain. Signs the EIP-712 attestation.
UNDERWRITER_PRIVATE_KEY=0x...
# Gemini (via OpenRouter, OpenAI-compatible) writes the human-readable rationale. https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Model slug; defaults to google/gemini-3-flash-preview if unset.
CREDO_LLM_MODEL=google/gemini-3-flash-preview
# Etherscan V2 multichain key — enriches cross-chain signals (wallet age, DeFi breadth). Optional.
ETHERSCAN_API_KEY=
# Optional Ethereum mainnet RPC for balance/tx reads (a fast private RPC avoids public-node timeouts).
# ETH_RPC_URL=

# Optional: point the UI at a standalone Express underwriter instead of the same-origin route.
# NEXT_PUBLIC_UNDERWRITER_URL=http://localhost:8791
