# Deployer / admin key (funded with HSK gas). NEVER commit the real .env.
PRIVATE_KEY=0x...

# AI underwriter signer address (derived from the underwriter service key in /underwriter).
# If unset, the deployer address is used and you can call setUnderwriter() later.
UNDERWRITER_ADDRESS=0x...

# Where seized collateral is sent on default. Defaults to deployer.
TREASURY_ADDRESS=0x...

# RPCs are defined in foundry.toml as hsk_testnet (133) / hsk_mainnet (1719).
