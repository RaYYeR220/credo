# Chain to underwrite against (133 = HSK testnet, 177 = HSK mainnet)
CHAIN_ID=133
PORT=8787

# Underwriter signing key — its address MUST equal CreditManager.underwriter (set at deploy
# via UNDERWRITER_ADDRESS, or later via setUnderwriter). Without it, quotes are unsigned.
UNDERWRITER_PRIVATE_KEY=0x...

# Gemini (via OpenRouter, OpenAI-compatible) writes the rationale layer. Without it, a deterministic
# template is used (numbers unchanged). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Model slug; defaults to google/gemini-3-flash-preview. Override for cost/quality if you want.
CREDO_LLM_MODEL=google/gemini-3-flash-preview

# Optional: Etherscan V2 multichain key enriches cross-chain signals (wallet age, DeFi breadth).
ETHERSCAN_API_KEY=

# Optional: custom Ethereum mainnet RPC for cross-chain history (defaults to a public endpoint).
ETH_RPC_URL=

# Loan parameters
LOAN_TERM_SECONDS=2592000      # 30 days
ATTESTATION_TTL_SECONDS=3600   # 1 hour validity for a signed quote